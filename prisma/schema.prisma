datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Repository {
  id            String         @id @default(uuid()) @db.Uuid
  owner         String         @map("owner")
  repo          String         @map("repo")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@unique([owner, repo], map: "repositories_owner_repo_key")
  @@map("repositories")
}

model Subscription {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @map("email")
  confirmed         Boolean    @default(false) @map("confirmed")
  confirmationToken String     @unique @map("confirmation_token")
  unsubscribeToken  String     @unique @map("unsubscribe_token")
  lastSeenTag       String?    @map("last_seen_tag")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  repositoryId      String     @map("repository_id") @db.Uuid
  repository        Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([email, repositoryId], map: "subscriptions_email_repository_id_key")
  @@index([repositoryId, confirmed], map: "subscriptions_repository_id_confirmed_idx")
  @@index([email, confirmed], map: "subscriptions_email_confirmed_idx")
  @@map("subscriptions")
}
