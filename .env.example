# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/release_notifier?schema=public

# Application
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# GitHub
GITHUB_TOKEN=ghp_your_token_here

# Redis (optional — GitHub API response cache; omit to disable)
REDIS_URL=redis://localhost:6379

# Email (MailHog defaults for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@releases-api.app

# Scanner
SCANNER_INTERVAL_MS=300000

# CORS (optional — defaults to * if omitted)
CORS_ORIGIN=*

# API Authentication (optional -- leave empty to disable)
API_SECRET_KEY=
